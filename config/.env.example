# OLXify Environment Configuration
# Copy this file to .env and fill in your values

# Google Sheets Integration
# Find your Sheet ID in the URL: docs.google.com/spreadsheets/d/[THIS-IS-YOUR-ID]/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Optional unattended auth for local/server runs.
# Prefer config/service_account.json for local use, or set this to minified one-line JSON.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
